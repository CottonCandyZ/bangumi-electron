{
  "name": "bangumi-electron-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter bangumi-electron build",
    "build:bangumi:win:beta": "pnpm --filter bangumi-electron build:win:beta",
    "build:bangumi:win:prod": "pnpm --filter bangumi-electron build:win:prod",
    "dev": "pnpm --filter bangumi-electron dev",
    "format": "pnpm --filter bangumi-electron format",
    "lint": "pnpm --filter bangumi-electron lint",
    "prepare": "husky",
    "publish:bangumi:win:beta": "pnpm --filter bangumi-electron publish:win:beta",
    "publish:bangumi:win:prod": "pnpm --filter bangumi-electron publish:win:prod",
    "start": "pnpm --filter bangumi-electron start",
    "turnstile:build": "pnpm --filter bangumi-private-api-turnstile-demo build",
    "turnstile:dev": "pnpm --filter bangumi-private-api-turnstile-demo dev",
    "typecheck": "pnpm --filter bangumi-electron typecheck"
  },
  "devDependencies": {
    "husky": "^9.1.6"
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748"
}
